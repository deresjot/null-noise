# Oeffentliche URL der Instanz fuer Metadata und Open Graph
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Lokale Persistenz fuer Titel, Seed-Daten und anonyme Bewertungen
DATABASE_URL="file:./prisma/null-noise.db"

# Optional: externe Titeldaten serverseitig ueber TMDb ergaenzen
METADATA_SPIKE_SOURCE=tmdb
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token

# Optional: Schreibpfade lokal oder spaeter auf einer echten Persistenz aktivieren
NULL_NOISE_ENABLE_WRITES=true
NULL_NOISE_RATE_LIMIT_SALT=change-me-before-public-write-use

# Nur fuer den spaeteren IMDb-Spike vorbereitet, nicht fuer die erste Beta noetig
IMDB_API_KEY=your_imdb_api_key
IMDB_DATA_SET_ID=your_imdb_data_set_id
IMDB_REVISION_ID=your_imdb_revision_id
IMDB_ASSET_ID=your_imdb_asset_id
IMDB_AWS_REGION=us-east-1
