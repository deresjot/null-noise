# Öffentliche URL der Instanz für Metadata und Open Graph
# Auf Vercel optional, aber für eine feste kanonische URL empfohlen.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: lokale Persistenz für Seed-Daten, lokale Titelseiten und spätere Schreibpfade
# Für den öffentlichen read-only MVP auf Vercel kann DATABASE_URL leer bleiben.
DATABASE_URL="file:./prisma/null-noise.db"

# Erforderlich: externe Titeldaten serverseitig über TMDb ergänzen
# Für diesen MVP wird ein TMDb Read Access Token erwartet.
METADATA_SPIKE_SOURCE=tmdb
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token

# Optional: Letterboxd-Zusatzblick für Filme nach TMDb-ID
LETTERBOXD_CLIENT_ID=your_letterboxd_client_id
LETTERBOXD_CLIENT_SECRET=your_letterboxd_client_secret

# Optional: direkte Anbieterlinks, Preise und Formate bei "Verfügbar bei"
WATCHMODE_API_KEY=your_watchmode_api_key

# Optional vorbereitet: externe Evidenzquellen für spätere interne Ersteinschätzung
# Ohne Flag und echten Key bleiben beide Adapter Noop/Fallback.
ENABLE_DTTD_EVIDENCE=false
DOES_THE_DOG_DIE_API_KEY=your_does_the_dog_die_api_key
ENABLE_CSM_EVIDENCE=false
COMMON_SENSE_MEDIA_API_KEY=your_common_sense_media_api_key

# Optional: nur mit echter Persistenz und bewusstem Public-Write-Freigabewunsch setzen
NULL_NOISE_ENABLE_WRITES=false
NULL_NOISE_RATE_LIMIT_SALT=change-me-before-public-write-use

# Nur für den späteren IMDb-Spike vorbereitet, nicht für die erste Beta nötig
IMDB_API_KEY=your_imdb_api_key
IMDB_DATA_SET_ID=your_imdb_data_set_id
IMDB_REVISION_ID=your_imdb_revision_id
IMDB_ASSET_ID=your_imdb_asset_id
IMDB_AWS_REGION=us-east-1
