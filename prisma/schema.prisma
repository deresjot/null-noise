generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TitleKind {
  movie
  series
}

enum ConfidenceLevel {
  niedrig
  mittel
  hoch
}

enum AggregateSourceType {
  editorial_seed
  provisional_seed
  metadata_inference
  community_median
  mixed
}

enum RatingSourceType {
  seed
  anonymous
}

enum RatingAttemptStatus {
  accepted
  rejected_rate_limited
  rejected_cooldown
  rejected_too_fast
  suspicious
}

enum TitleImportAttemptStatus {
  accepted
  rejected_rate_limited
  suspicious
}

model ExternalTitle {
  id                        String              @id @default(cuid())
  externalSource            String
  externalSourceId          String
  slug                      String              @unique
  title                     String
  originalTitle             String?
  kind                      TitleKind
  releaseYear               Int?
  synopsis                  String?
  runtimeMinutes            Int?
  posterPath                String?
  languageCode              String              @default("de")
  profileNotes              String
  profileBaseSourceType     AggregateSourceType
  profileBaseLastReviewedAt DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  aggregate                 StimulusAggregate?
  ratings                   TitleRating[]
  contentFlags              ContentFlag[]

  @@unique([externalSource, externalSourceId])
}

model StimulusAggregate {
  id              String              @id @default(cuid())
  titleId         String              @unique
  volumeLevel     Int
  peakIntensity   Int
  stimulusDensity Int
  soothingEffect  Int
  confidenceLevel ConfidenceLevel
  ratingCount     Int                 @default(0)
  sourceType      AggregateSourceType
  lastReviewedAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  title           ExternalTitle       @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@index([sourceType, lastReviewedAt])
}

model TitleRating {
  id              String           @id @default(cuid())
  titleId         String
  sourceType      RatingSourceType
  volumeLevel     Int
  peakIntensity   Int
  stimulusDensity Int
  soothingEffect  Int
  submittedAt     DateTime         @default(now())
  title           ExternalTitle    @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@index([titleId, submittedAt])
  @@index([sourceType])
}

model ContentFlag {
  id          String        @id @default(cuid())
  titleId     String
  flag        String
  description String?
  title       ExternalTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([titleId, flag])
}

model RatingAttempt {
  id          String              @id @default(cuid())
  titleSlug   String
  ipHash      String
  status      RatingAttemptStatus
  submittedAt DateTime            @default(now())

  @@index([titleSlug, submittedAt])
  @@index([ipHash, submittedAt])
}

model TitleImportAttempt {
  id          String                   @id @default(cuid())
  sourceKey   String
  ipHash      String
  status      TitleImportAttemptStatus
  submittedAt DateTime                 @default(now())

  @@index([sourceKey, submittedAt])
  @@index([ipHash, submittedAt])
}
