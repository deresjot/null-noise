{
  "name": "null-noise",
  "version": "0.8.3",
  "private": true,
  "description": "Barrierearmes MVP-Grundgeruest fuer null-noise",
  "scripts": {
    "db:push": "node --import tsx prisma/init-sqlite.ts",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:bootstrap": "npm run db:push && npm run db:seed",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test:unit": "DATABASE_URL=file:./prisma/test.db NULL_NOISE_SKIP_LEGACY_IMPORT=true npm run db:push && DATABASE_URL=file:./prisma/test.db NULL_NOISE_SKIP_LEGACY_IMPORT=true vitest run --maxWorkers=1",
    "test:a11y": "playwright test tests/accessibility.spec.ts tests/axe-core-direct.spec.ts",
    "test:axe-core": "playwright test tests/axe-core-direct.spec.ts",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "accessibility",
    "privacy",
    "nextjs",
    "wcag"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dataexchange": "^3.1014.0",
    "@prisma/client": "^6.19.2",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.11.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
